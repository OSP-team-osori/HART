{
  "id": null,
  "uid": "hart-agent-monitoring",
  "title": "HART - Agent Monitoring",
  "tags": ["hart", "agent"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "총 실행 횟수",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "hart-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS value FROM task_results",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "성공률",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "hart-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN is_success THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS value FROM task_results",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "평균 실행 시간",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "hart-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(AVG(execution_time_ms) / 1000.0, 1) AS value FROM task_results",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "총 누적 비용",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "hart-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(CAST(SUM(cost) AS NUMERIC), 4) AS value FROM task_results",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "테스트 결과 분포",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "hart-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT test_status AS metric, COUNT(*) AS value FROM task_results GROUP BY test_status",
          "format": "table"
        }
      ],
      "options": {
        "pieType": "pie",
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "PASS" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "FAIL" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "SKIPPED" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "시간별 토큰 사용량",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 4 },
      "datasource": { "type": "postgres", "uid": "hart-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT at.created_at AS time, tr.tokens_used AS \"토큰 사용량\" FROM agent_tasks at JOIN task_results tr ON tr.task_id = at.id WHERE $__timeFilter(at.created_at) ORDER BY at.created_at",
          "format": "time_series"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "최근 실행 기록",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "hart-postgres" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT at.created_at AS \"실행 시각\", LEFT(at.prompt, 60) AS \"프롬프트\", tr.test_status AS \"결과\", ROUND(tr.execution_time_ms / 1000.0, 1) AS \"실행시간(s)\", tr.tokens_used AS \"토큰\", ROUND(CAST(tr.cost AS NUMERIC), 4) AS \"비용($)\", tr.test_summary AS \"요약\" FROM agent_tasks at JOIN task_results tr ON tr.task_id = at.id ORDER BY at.created_at DESC LIMIT 20",
          "format": "table"
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "실행 시각", "desc": true }]
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "결과" }, "properties": [{ "id": "custom.width", "value": 80 }, { "id": "mappings", "value": [{ "type": "value", "options": { "PASS": { "text": "PASS", "color": "green", "index": 0 }, "FAIL": { "text": "FAIL", "color": "red", "index": 1 }, "SKIPPED": { "text": "SKIPPED", "color": "yellow", "index": 2 } } }] }, { "id": "custom.displayMode", "value": "color-background" }] },
          { "matcher": { "id": "byName", "options": "실행시간(s)" }, "properties": [{ "id": "custom.width", "value": 110 }] },
          { "matcher": { "id": "byName", "options": "토큰" }, "properties": [{ "id": "custom.width", "value": 80 }] },
          { "matcher": { "id": "byName", "options": "비용($)" }, "properties": [{ "id": "custom.width", "value": 90 }] }
        ]
      }
    }
  ]
}
